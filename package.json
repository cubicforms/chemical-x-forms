{
  "name": "@chemical-x/forms",
  "version": "0.10.0",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cubicforms/chemical-x-forms"
  },
  "scripts": {
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "unbuild --stub && nuxi prepare playground",
    "lint": "eslint --ext .ts,.js,.vue .",
    "lint:fix": "eslint --ext .ts,.js,.vue . --fix",
    "format": "prettier --write '**/*.{ts,js,vue,css,scss,md,json,yml,yaml}'",
    "format:check": "prettier --check '**/*.{ts,js,vue,css,scss,md,json,yml,yaml}'",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm check:size && pnpm check:bench && pnpm check:coverage",
    "fix": "npm run lint:fix && npm run format",
    "typecheck": "tsc --noEmit",
    "prepack": "unbuild",
    "prepack:watch": "chokidar 'src/**/*' -c 'pnpm prepack' --initial",
    "release": "pnpm check && pnpm version patch && pnpm prepack && pnpm publish && git push --follow-tags",
    "test": "vitest run",
    "test:types": "pnpm dev:prepare && vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "test:watch": "vitest watch",
    "bench": "vitest bench --run",
    "check:size": "pnpm prepack && size-limit",
    "check:coverage": "vitest run --coverage",
    "check:bench": "node scripts/check-bench.mjs",
    "version": "node scripts/promote-changelog.mjs && (node scripts/generate-release-notes.mjs || echo '[version] release-notes step failed; continuing') && git add CHANGELOG.md RELEASES.md",
    "prepare": "husky"
  },
  "description": "A fully type-safe, schema-driven form library that gives you superpowers. Chemical X included.",
  "author": "Oswald Chisala",
  "bugs": {
    "url": "https://github.com/cubicforms/chemical-x-forms/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.mts",
      "import": "./dist/nuxt.mjs",
      "require": "./dist/nuxt.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./transforms": {
      "types": "./dist/transforms.d.mts",
      "import": "./dist/transforms.mjs"
    },
    "./zod": {
      "types": "./dist/zod.d.mts",
      "import": "./dist/zod.mjs"
    },
    "./zod-v3": {
      "types": "./dist/zod-v3.d.mts",
      "import": "./dist/zod-v3.mjs"
    },
    "./types": {
      "types": "./dist/index.d.mts"
    }
  },
  "keywords": [
    "vue3",
    "nuxt3",
    "forms",
    "composable",
    "cubic forms",
    "@chemical-x/forms",
    "form manager",
    "chemical x"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.7.0",
  "type": "module",
  "lint-staged": {
    "./src/**/*.{ts,vue}": "eslint",
    "./playground/**/*.{ts,vue}": "eslint",
    "./test/**/*.{ts,vue}": "eslint"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@fast-check/vitest": "^0.4.0",
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.2",
    "@rollup/plugin-alias": "^6.0.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/jsdom": "^28.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/compiler-core": "^3.5.33",
    "@vue/devtools-api": "^8.1.1",
    "@vue/server-renderer": "^3.5.33",
    "changelogen": "^0.6.2",
    "cheerio": "^1.2.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "immer": "^11.1.4",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "lodash-es": "^4.18.1",
    "nuxt": "^4.4.2",
    "prettier": "^3.8.3",
    "rollup-plugin-dts": "^6.4.1",
    "size-limit": "^12.1.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "unbuild": "^3.6.1",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7",
    "zod": "^4.3.6",
    "zod-v3": "npm:zod@^3.24"
  },
  "peerDependencies": {
    "@vue/compiler-core": ">=3.5.0",
    "@vue/devtools-api": "^6.6.0 || ^7.0.0",
    "lodash-es": ">= 4.0.0",
    "nuxt": ">=3.0.0",
    "vite": ">=5.0.0",
    "vue": ">=3.5.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/devtools-api": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
