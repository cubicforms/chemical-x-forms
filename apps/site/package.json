{
  "name": "attaform-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/clean-stale-cache.mjs && pnpm bundle:repl && pnpm index:search:dev && (pnpm bundle:repl:watch & nuxi dev)",
    "build": "pnpm -w dev:prepare && pnpm typecheck && pnpm bundle:repl && NODE_ENV=production nuxi build && pnpm index:search && pnpm index:bing",
    "generate": "pnpm -w dev:prepare && pnpm typecheck && pnpm bundle:repl && NODE_ENV=production nuxi generate && pnpm index:search && pnpm index:bing",
    "preview": "nuxi preview",
    "bundle:repl": "node scripts/bundle-repl-deps.mjs",
    "bundle:repl:watch": "node scripts/bundle-repl-deps.mjs --watch",
    "fonts:refresh": "node scripts/download-fonts.mjs && prettier --write assets/css/fonts.css",
    "index:search": "pagefind --site .output/public --output-path .output/public/_pagefind",
    "index:search:dev": "node scripts/index-search-dev.mjs",
    "index:bing": "node scripts/indexnow-ping.mjs",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/content": "^3.13.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/seo": "^5.1.3",
    "@resvg/resvg-js": "^2.6.2",
    "@shikijs/twoslash": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@vue/repl": "^4.7.2",
    "attaform": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "lucide-vue-next": "^1.0.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "esbuild": "^0.28.0",
    "github-slugger": "^2.0.0",
    "marked": "^15.0.0",
    "nuxt": "^4.4.2",
    "pagefind": "^1.5.0",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  }
}
