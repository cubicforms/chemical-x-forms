shamefully-hoist=false
strict-peer-dependencies=false

# Hoist the unified/remark/rehype ecosystem to the workspace root so
# Vite's optimizeDeps resolver (used by @nuxt/content's `@nuxtjs/mdc`)
# can satisfy `optimizeDeps.include` entries like `@nuxtjs/mdc >
# remark-gfm`. Without these, dev boot logs "Unresolvable
# optimizeDeps.include entries" for every transitive markdown dep —
# non-fatal, but noisy and skips pre-bundling perf.
public-hoist-pattern[]=*remark*
public-hoist-pattern[]=*rehype*
public-hoist-pattern[]=unified
public-hoist-pattern[]=*unist-util-*
public-hoist-pattern[]=parse5
public-hoist-pattern[]=parse5-htmlparser2-tree-adapter
